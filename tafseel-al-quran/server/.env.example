# Database (Using SQLite for smooth local & VPS deployments)
# If deploying to serverless (like Vercel), you must switch back to PostgreSQL.
DATABASE_URL="file:./dev.db"

# JWT Secrets (MUST CHANGE IN PRODUCTION)
JWT_ACCESS_SECRET="your-super-secret-access-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"

# Server
PORT=5000
NODE_ENV=production

# Client URL (Change this to your deployed React frontend URL, e.g., https://my-quran-app.vercel.app)
CLIENT_URL=http://localhost:5173

# Redis (optional - remove if not using caching)
REDIS_URL=redis://localhost:6379

# SMTP Configuration (optional - for emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Cloudinary (optional - for media)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
